{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@b24-doc-gen/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/http-proxy": "^8.4.0",
    "@fastify/multipart": "^8.2.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^9.1.0",
    "@prisma/client": "^5.14.0",
    "@turbodocx/html-to-docx": "^1.20.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "mammoth": "^1.12.0",
    "mathjs": "^15.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  }
