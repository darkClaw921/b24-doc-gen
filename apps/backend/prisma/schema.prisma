// Prisma schema for the b24-doc-gen backend.
// Datasource: local SQLite file (dev.db).
// Note: SQLite does not support enums or native JSON columns, so
// JSON-shaped data (arrays, objects) is stored in String columns and
// parsed on the application side.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Application-wide settings. Exactly one row (id = 1) is expected.
/// `adminUserIds` is a JSON-encoded array of Bitrix24 user IDs.
/// `dealFieldBinding` is the UF_CRM_* field code where generated
/// documents are attached, or null until the admin configures it.
model AppSettings {
  id               Int      @id @default(1)
  portalDomain     String
  adminUserIds     String
  dealFieldBinding String?
  /// Secret token that Bitrix24 sends on every bizproc robot / outgoing
  /// webhook call. Populated on first install (install.ts) from the
  /// `APP_SID` / `auth.application_token` field. Routes that accept
  /// Bitrix-originated callbacks validate the incoming token against
  /// this value to authenticate the caller.
  applicationToken String?
  /// OAuth tokens captured from the frontend BX24 SDK at install time.
  /// Used by server-to-server flows (e.g. the webhook executor) where
  /// there is no live iframe session to forward an access token from.
  /// `authExpiresAt` is the absolute expiry of `accessToken`; when it
  /// is in the past, the portalAuth service calls oauth.bitrix.info to
  /// exchange `refreshToken` for a fresh pair.
  accessToken      String?
  refreshToken     String?
  authExpiresAt    DateTime?
  /// Stable per-portal member id captured from the SDK. Used by the
  /// webhook executor to verify that an incoming robot callback really
  /// belongs to the installed portal (compared to auth[member_id] in
  /// the Bitrix payload).
  memberId         String?
  installedAt      DateTime @default(now())
}

/// A logical grouping of templates. Admins can create themes to
/// organize templates by purpose ("Contracts", "Invoices", etc).
/// Settings live on the Theme so admins can configure each "folder"
/// independently:
/// - `addToTimeline` — whether the generate pipeline posts a timeline
///   comment with the document attachment for templates inside this theme.
/// - `dealFieldBinding` — UF_CRM_* file field where the generated .docx
///   gets attached. Overrides the global AppSettings.dealFieldBinding
///   (which is kept as a fallback for legacy themes). If the underlying
///   field is multiple, the generate route appends to the existing list
///   instead of replacing it.
model Theme {
  id               String     @id @default(cuid())
  name             String
  order            Int        @default(0)
  addToTimeline    Boolean    @default(true)
  dealFieldBinding String?
  templates        Template[]
  webhooks         Webhook[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

/// A document template uploaded and edited by admins.
/// - contentHtml holds the TipTap representation with <formula-tag>
///   inline nodes.
/// - originalDocx is the raw .docx bytes kept for re-editing.
model Template {
  id           String    @id @default(cuid())
  name         String
  themeId      String
  theme        Theme     @relation(fields: [themeId], references: [id])
  contentHtml  String
  originalDocx Bytes?
  formulas     Formula[]
  webhooks     Webhook[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([themeId])
}

/// A formula attached to a template.
/// - tagKey is referenced from contentHtml by the TipTap formula node.
/// - expression is a mathjs-compatible string.
/// - dependsOn is a JSON-encoded object listing the Bitrix24 field
///   codes read by the expression, grouped by entity (deal/contact/
///   company). Used to minimize REST calls during preview.
model Formula {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tagKey     String
  label      String
  expression String
  dependsOn  String

  @@unique([templateId, tagKey])
  @@index([templateId])
}

/// A webhook trigger for document generation. Created by admins and
/// invoked by Bitrix24 "Outgoing webhook" robots. When Bitrix POSTs to
/// /api/webhook/run/:token, the backend runs the same generation
/// pipeline as the manual UI button for every Template in scope.
///
/// - `token` is a URL-safe cryptorandom string (base64url, 32+ bytes).
/// - `scope` is either "theme" (generate all Templates inside a Theme)
///   or "template" (generate a single Template). Exactly one of
///   `themeId`/`templateId` is set depending on scope.
/// - `enabled` lets admins temporarily pause a webhook without
///   deleting it.
/// - `lastUsedAt`/`useCount` are maintained by the executor endpoint
///   for basic observability.
model Webhook {
  id         String    @id @default(cuid())
  token      String    @unique
  scope      String
  themeId    String?
  templateId String?
  label      String?
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  useCount   Int       @default(0)

  theme    Theme?    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([themeId])
  @@index([templateId])
}
