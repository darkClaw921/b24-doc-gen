# ----------------------------------------------------------------------
# b24-doc-gen environment variables
# Copy this file to `apps/backend/.env` and fill in the values.
# ----------------------------------------------------------------------

# Bitrix24 application credentials (from the "Local application" form
# on your Bitrix24 portal).
B24_APP_ID=local.000000000000000000.00000000
B24_APP_SECRET=your_bitrix24_app_secret_here

# SQLite database file used by Prisma.
# Relative paths are resolved from apps/backend (where prisma/schema.prisma lives).
DATABASE_URL="file:./dev.db"

# Backend HTTP server.
# Используй ЭТОТ порт для ngrok: `ngrok http 3001`
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# Public URL — ngrok/cloudflared/etc. туннель, указывающий на BACKEND_PORT.
# Именно этот URL нужно указывать в настройках локального приложения Bitrix24.
# В dev-режиме бэкенд перенаправляет GET / → Vite (5173) и отдаёт /api/* сам.
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# Frontend dev server (Vite) — только для локальной разработки.
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# Runtime environment. "development" enables pino-pretty logs.
NODE_ENV=development
LOG_LEVEL=info
